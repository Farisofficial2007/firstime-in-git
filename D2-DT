#---6---SIMPLE CALCULATOR

a=float(input("First number:"))
op=input("Operator (+,-,*,/):")
b=float(input("Second number:"))
if op=='+': 
  print(a+b)
elif op=='-':
  print(a-b)
elif op=='*':
  print(a*b)
elif op=='/':
  print(a/b if b!=0 else "Error")

OUTPUT

First number:5
Operator (+,-,*,/):*
Secound number:30
150
