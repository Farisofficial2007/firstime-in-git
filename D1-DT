print("---This program is to convert temperatures---")
print("Enter the no 1 to convert the Celsius to Fahrenheit")
print("Enter the no 2 to convert the Fahrenheit to celsius") 
a=int(input("Enter the option 1 or 2 :"))
if a==1 :
    b=int(input("Enter the Celsius temperature:"))
    c=(b* 9/5)+32
    print(b,"Celsius =",c,"Fahrenheit")
elif a==2 :
    b=int(input("Enter the Fahrenheit temperature:"))
    c=(b-32)* 5/9
    print(b,"Fahrenheir =",c,"Celsius")
else :
    print("Entered an wrong number")
