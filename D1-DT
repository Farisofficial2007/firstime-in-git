2nd TASK *PROGRAM SIMPLE CALCULATER 
--------------------------------------------------------------------------
print("---Simple Calculater---")
a=float(input("Enter first number:"))
op=input("Operations ( + | - | * | / ) choose any:").strip()
b=float(input("Enter second number:"))
if op == '+' :
    print(a, "+",b,"=",a+b)
elif op == '-':
    print(a, "-",b, "=",a-b)
elif op == '*' :
    print(a, "*",b, "=",a*b)
elif op == '/' :
    print(a, "/",b, "=",a/b)
else :
    print("Error:Please enter the valid number")
